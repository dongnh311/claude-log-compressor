{
  "name": "@dongnh311/claude-context-saver",
  "version": "0.2.0",
  "description": "MCP server that cuts Claude Code token usage. Two capabilities: log compression (build/test/install output) and smart file reading (AST-backed symbol-level source access). Context-efficient tooling for Pro-tier users.",
  "keywords": [
    "mcp",
    "claude-code",
    "anthropic",
    "claude",
    "token-optimization",
    "log-compression",
    "tree-sitter",
    "ast",
    "gradle",
    "npm",
    "jest",
    "pytest",
    "kotlin",
    "typescript"
  ],
  "license": "MIT",
  "author": "dongnh <hoaidongit5@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongnh311/claude-context-saver.git"
  },
  "bugs": {
    "url": "https://github.com/dongnh311/claude-context-saver/issues"
  },
  "homepage": "https://github.com/dongnh311/claude-context-saver#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-context-saver": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "clean": "rm -rf dist",
    "bench": "tsx scripts/benchmark.ts",
    "bench:file": "tsx scripts/bench-file-side.ts",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
